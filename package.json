{
  "name": "jj-kanban",
  "version": "0.1.0",
  "description": "JJ Kanban — configurable drag & drop board for Dynamics 365 / Dataverse.",
  "private": true,
  "scripts": {
    "build": "pcf-scripts build",
    "clean": "pcf-scripts clean",
    "lint": "pcf-scripts lint",
    "lint:fix": "pcf-scripts lint fix",
    "rebuild": "pcf-scripts rebuild",
    "start": "pcf-scripts start",
    "start:watch": "pcf-scripts start watch",
    "refreshTypes": "pcf-scripts refreshTypes",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "e2e:auth": "playwright test --config=playwright.live.config.ts --project=setup --headed",
    "test:live": "playwright test --config=playwright.live.config.ts --project=live",
    "verify": "npm run test:coverage && npm run build && npm run test:e2e",
    "verify:live": "npm run verify && npm run test:live"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fluentui/react-components": "9.46.2",
    "react": "16.14.0",
    "react-dom": "16.14.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.25.1",
    "@microsoft/eslint-plugin-power-apps": "^0.2.51",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^12.1.5",
    "@types/jest": "^30.0.0",
    "@types/powerapps-component-framework": "^1.3.16",
    "@types/react": "^16.14.60",
    "@types/react-dom": "^16.9.24",
    "esbuild": "^0.25.12",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-react": "^7.37.2",
    "globals": "^15.15.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "pcf-scripts": "^1",
    "pcf-start": "^1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.44.0"
  }
}
